# Supabase public frontend configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct PostgreSQL connection string (shared pooler) — for migrations & scripts.
# Get it from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=

# Canonical production URL used by metadata, sitemap, robots and password reset.
# Example: https://newbrothers.uy
NEXT_PUBLIC_SITE_URL=

# AI assistant providers. Optional: the app falls back to local rules if unset.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Supabase Edge Function secrets for send-reminders only.
# Configure with: supabase secrets set SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=...
# Never expose SUPABASE_SERVICE_ROLE_KEY in browser or Vercel frontend env vars.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Demo mode: solo para deploys demo (ej. Vercel preview público); no setear en producción real.
# Habilita el quick-login "Entrar como Admin demo" en /admin-login y /login.
# Las credenciales quedan expuestas en el bundle del cliente a propósito (demo pública).
NEXT_PUBLIC_DEMO_MODE=
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=
