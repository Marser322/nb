# Supabase public frontend configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct PostgreSQL connection string (shared pooler) — for migrations & scripts.
# Get it from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=

# Canonical production URL used by metadata, sitemap, robots and password reset.
# Example: https://newbrothers.uy
NEXT_PUBLIC_SITE_URL=

# AI assistant providers. Optional: the app falls back to local rules if unset.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Modo demo — usar solo en proyectos descartables/solo-demo.
# NEXT_PUBLIC_DEMO_MODE va al browser y habilita el boton "Entrar como Admin demo".
# DEMO_ADMIN_* y SUPABASE_SERVICE_ROLE_KEY quedan solo en servidor: auto-crean/reparan el admin demo.
NEXT_PUBLIC_DEMO_MODE=true
DEMO_ADMIN_EMAIL=demo@nbbarber.uy
DEMO_ADMIN_PASSWORD=DemoNB2026!
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Compatibilidad legacy: si ya tenes estas variables publicas, el flujo demo las usa como fallback.
# No recomendadas para demos con datos sensibles.
# NEXT_PUBLIC_DEMO_ADMIN_EMAIL=demo@nbbarber.uy
# NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=DemoNB2026!

# Supabase Edge Function secrets for send-reminders only.
# Configure with: supabase secrets set SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=...
# Never expose SUPABASE_SERVICE_ROLE_KEY in browser or variables NEXT_PUBLIC_*.
