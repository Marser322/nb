# Supabase public frontend configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct PostgreSQL connection string (shared pooler) — for migrations & scripts.
# Get it from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=

# Canonical production URL used by metadata, sitemap, robots and password reset.
# Example: https://newbrothers.uy
NEXT_PUBLIC_SITE_URL=

# AI assistant providers. Optional: the app falls back to local rules if unset.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Supabase Edge Function secrets for send-reminders only.
# Configure with: supabase secrets set SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=...
# Never expose SUPABASE_SERVICE_ROLE_KEY in browser or Vercel frontend env vars.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Modo demo (publicas, van al browser) — setear tambien en Vercel para la demo.
# Habilita el quick-login "Entrar como Admin demo" en /admin-login y /login.
# Usar solo en proyectos descartables/solo-demo: estas credenciales son publicas por diseno.
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=demo@nbbarber.uy
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=DemoNB2026!

# Solo para correr scripts/seed-demo-admin.mjs en local. NUNCA commitear valores reales ni subir a Vercel.
# SUPABASE_URL permite apuntar temporalmente a una DB destino distinta de NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
